# Single entry point for the frontend. Each service runs separately with its own .env + DB.
PORT=5000
AUTH_SERVICE_URL=http://localhost:5001
INVENTORY_SERVICE_URL=http://localhost:5003
SALES_SERVICE_URL=http://localhost:5004
SUPPLIER_SERVICE_URL=http://localhost:5005

# Optional: legacy monolith (AI, email jobs, etc.) — only if you still run root server.js on 5002
LEGACY_MONOLITH_URL=http://localhost:5002
