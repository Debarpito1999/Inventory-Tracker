# inventory-service — only inventory_db (MONGO_URI)
PORT=5003
MONGO_URI=mongodb://127.0.0.1:27017/inventory_db
JWT_SECRET=must_match_auth_service_secret

# Service-to-service: call supplier-service (same host/port you use in api-gateway SUPPLIER_SERVICE_URL)
SUPPLIER_SERVICE_URL=http://localhost:5005
